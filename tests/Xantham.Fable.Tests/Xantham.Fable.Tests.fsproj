<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TestProject>true</TestProject>
        <DefineConstants>FABLE_TEST</DefineConstants>
        <TargetFramework>net10.0</TargetFramework>
    </PropertyGroup>

    <ItemGroup>
        <Compile Include="Program.fs"/>
        <TypeScriptCompile Include="TypeFiles\basic.d.ts" />
