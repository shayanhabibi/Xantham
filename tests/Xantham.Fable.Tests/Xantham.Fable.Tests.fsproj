        <TypeScriptCompile Include="TypeFiles\multiple-extends.d.ts" />
        <TypeScriptCompile Include="TypeFiles\enum.d.ts" />
        <TypeScriptCompile Include="TypeFiles\members.d.ts" />
        <TypeScriptCompile Include="TypeFiles\function.d.ts" />
        <TypeScriptCompile Include="TypeFiles\generics.d.ts" />
        <TypeScriptCompile Include="TypeFiles\overloads.d.ts" />
        <TypeScriptCompile Include="TypeFiles\optional-readonly.d.ts" />
        <TypeScriptCompile Include="TypeFiles\index-access.d.ts" />
        <TypeScriptCompile Include="TypeFiles\class.d.ts" />
        <TypeScriptCompile Include="TypeFiles\tuple.d.ts" />
        <TypeScriptCompile Include="TypeFiles\union.d.ts" />
        <TypeScriptCompile Include="TypeFiles\variable.d.ts" />
        <TypeScriptCompile Include="TypeFiles\intersection.d.ts" />
        <TypeScriptCompile Include="TypeFiles\utility-types.d.ts" />
        <TypeScriptCompile Include="TypeFiles\type-operators.d.ts" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\src\Xantham.Fable\Xantham.Fable.fsproj" />
    </ItemGroup>

    <ItemGroup>
      <PackageReference Include="Fable.Mocha" Version="2.17.0" />
    </ItemGroup>

</Project>
