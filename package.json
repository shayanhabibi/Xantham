{
    "type": "module",
    "name": "xantham",
    "author": "shayanhabibi",
    "repository": "https://github.com/shayanhabibi/xantham",
    "description": "CLI for generating Xantham IR json.",
    "version": "0.0.3",
    "bin": "./index.js",
    "main": "index.js",
    "license": "Apache-2.0",
    "publishConfig": {},
    "files": [
        "src/Xantham.Fable/output/",
        "index.js"
    ],
    "engines": {
        "node": ">=16"
    },
    "scripts": {
        "pretest": "dotnet fable -c Debug -e .fs.js --cwd tests/Xantham.Fable.Tests -o dist/tests",
        "test": "mocha tests/Xantham.Fable.Tests/dist/tests",
        "watch-test": "dotnet fable --cwd tests/Xantham.Fable.Tests -e .fs.js --noCache --watch --runWatch mocha Program.fs.js",
        "prestart": "dotnet fable --cwd src/Xantham.Fable -o output -e .fs.js",
        "start": "node src/Xantham.Fable/output/Program.fs.js",
        "run": "dotnet fable --cwd src/Xantham.Fable -e .fs.js -c DEBUG --noCache -o output --run node output/Program.fs.js",
        "watch": "dotnet fable --cwd src/Xantham.Fable --noCache -e .fs.js -o output --watch --run node --watch output/Program.fs.js",
        "test:signal": "dotnet fable --cwd tests/ --noCache Signal.test.fsx && node tests/Signal.test.fs.js",
        "prebuild": "dotnet fable --cwd src/Xantham.Fable -c Release --noCache -o output -e .fs.js",
        "build": ""
    },
    "devDependencies": {
        "@cloudflare/codemode": "0.4.2",
        "@cloudflare/workers-types": "4.20260630.1",
        "@modelcontextprotocol/sdk": "1.29.0",
        "agents": "0.17.1",
        "mocha": "^11.7.5",
        "partyserver": "0.5.8",
        "partysocket": "1.3.0",
        "zod": "4.4.3"
    },
    "dependencies": {
        "chalk": "^5.3.0",
        "smol-toml": "^1.7.0",
        "typescript": "^5.9.3"
    }
}
