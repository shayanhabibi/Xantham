{
    "type": "module",
    "main": "index.js",
    "engines": {
        "node": ">=16"
    },
    "scripts": {
        "pretest": "dotnet fable -c Debug --cwd tests/Xantham.Fable.Tests -o dist/tests",
        "test": "mocha tests/Xantham.Fable.Tests/dist/tests",
        "watch-test": "dotnet fable --cwd tests/Xantham.Fable.Tests --noCache --watch --runWatch mocha Program.fs.js",
        "prestart": "dotnet fable --cwd src/Xantham.Fable",
        "start": "node src/Xantham.Fable/Program.fs.js",
        "run": "dotnet fable --cwd src/Xantham.Fable --noCache --run node Program.fs.js",
        "watch": "dotnet fable --cwd src/Xantham.Fable --noCache --watch --run node --watch Program.fs.js",
        "test:signal": "dotnet fable --cwd tests/ --noCache Signal.test.fsx && node tests/Signal.test.fs.js"
    },
    "devDependencies": {
        "mocha": "^11.7.5",
        "@iconify-icons/lucide": "^1.2.135",
        "@iconify-icons/simple-icons": "^1.2.74",
        "@iconify/react": "^4.1.1",
        "@monaco-editor/react": "^4.6.0",
        "@vitejs/plugin-react": "^4.2.1",
        "@vitest/ui": "^1.5.0",
        "ansi-colors": "^4.1.3",
        "bulma": "^0.9.4",
        "diff": "^5.2.0",
        "dirname-filename-esm": "^1.1.1",
        "fable-css-modules": "^1.8.0",
        "gh-pages": "^6.1.1",
        "lz-string": "^1.5.0",
        "monaco-editor": "^0.46.0",
        "nodemon": "^3.1.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "sass": "^1.75.0",
        "solid-js": "^1.9.10",
        "ts-morph": "^27.0.2",
        "vite": "^5.2.9",
        "vitest": "^1.5.0"
    },
    "dependencies": {
        "@ts-morph/bootstrap": "^0.28.1",
        "chalk": "^5.3.0",
        "typescript": "^5.9.3"
    }
}
